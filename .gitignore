# Data generation intermediate files
data-generation/**/output/

# Impeccable design skill — local dev tooling only (the PostToolUse hook reads
# from .claude/skills/impeccable). Vendored bundles aren't app code and tripped
# `eslint .` in CI; keep them on disk, out of version control.
.claude/skills/
.github/skills/

# Research source material — third-party copyrighted PDFs (papers, analyst decks).
# We cite these in-code (author, year, figures) but must NOT publish the documents
# themselves. Keep them on disk under docs/research/, out of version control.
# Markdown notes / our own synthesis in this folder remain committable.
docs/research/*.pdf

# Cache
.cache
